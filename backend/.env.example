PORT=3000
NODE_ENV=development
LOG_LEVEL=INFO
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=leetjudge
DB_HOST=127.0.0.1
DB_PORT=5434
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass
JWT_SECRET=supersecretjwtkey
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=onboarding@resend.dev

# Rate Limiting (in milliseconds and max requests)
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_STRICT_WINDOW_MS=300000
RATE_LIMIT_STRICT_MAX=20

# Caching (in seconds)
CACHE_TTL_PROBLEMS_LIST=60
CACHE_TTL_PROBLEM_DETAIL=300
CACHE_TTL_CONTEST_PROBLEMS=3600
CONTEST_CACHE_WARMUP_INTERVAL_SEC=60

# Security & OTP
JWT_EXPIRY=1d
OTP_EXPIRATION_MINUTES=10

# Storage
STORAGE_PROVIDER=github
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=your_username/your_repository
GITHUB_BRANCH=main
